---
---

<section class="safe-space-section section">
    <div class="container">
        <div class="safe-space-grid">
            <!-- Left Side: Text Content -->
            <div class="safe-space-content reveal">
                <span class="section-label">Your Business, Our Knowledge</span>
                <h2>Thinking about starting a business?<br><em>The right knowledge is your foundation.</em></h2>
                
                <p class="lead-text">
                    Sharing knowledge to support better Small Business decisions: planning and strategy, employing, contracts, dealing with red tape, and everyday management. Our contributors are small business owners, accountants, lawyers, brokers and consultants.
                </p>
                <p class="lead-text">
                    Growing to become a voice to support and advocate for all Small Businesses in Australia.
                </p>
                <a href="/about" class="btn-ghost-dark" style="margin-top: 1rem;">Learn more about SBI <span>→</span></a>
            </div>

            <!-- Right Side: Stats Panel (moved from Who We Are) -->
            <div class="stats-panel reveal reveal-delay-2">
                <div class="stats-grid">
                    <div class="stat-card">
                        <span class="stat-num">2.5M+</span>
                        <span class="stat-label">small businesses<br>in Australia</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-num">97%</span>
                        <span class="stat-label">of all Australian<br>businesses</span>
                    </div>
                    <div class="stat-card stat-card-wide">
                        <span class="stat-num">1 in 3</span>
                        <span class="stat-label">Australians work for or own a small business</span>
                    </div>
                </div>
                <p class="stat-footnote">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                    Most run without a support network. We're here to change that.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
.safe-space-section {
    padding: 6rem 0;
    background: #f8fafc; /* light gray/blue tint */
    border-bottom: 1px solid var(--border);
}

.container {
    position: relative;
    z-index: 1;
}

.safe-space-grid {
    display: grid;
    gap: 4rem;
    align-items: center;
}
@media (min-width: 900px) {
    .safe-space-grid {
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
    }
}

.section-label {
    display: inline-block;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--navy);
    background: #e2e8f0;
    border-radius: 50px;
    margin-bottom: 1.5rem;
}

.safe-space-content h2 {
    font-size: clamp(2.2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 1.25rem;
    line-height: 1.15;
}

.safe-space-content h2 em {
    font-style: normal;
    color: var(--accent);
}

.lead-text {
    font-size: 1.15rem;
    color: var(--navy-mid);
    line-height: 1.6;
    margin-bottom: 1.2rem;
}

.btn-ghost-dark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--navy);
    border: 1.5px solid var(--navy);
    padding: 0.8rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.25s ease;
    text-decoration: none;
}
.btn-ghost-dark:hover {
    background: var(--navy);
    color: var(--white);
    text-decoration: none;
}
.btn-ghost-dark span {
    transition: transform 0.25s ease;
}
.btn-ghost-dark:hover span {
    transform: translateX(4px);
}

/* Stats panel adapted for light theme */
.stats-panel {
    background: var(--white);
    border: 1.5px solid rgba(0,0,0,0.05);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: 0 10px 30px rgba(15,39,68,.05);
}

.stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
}

.stat-card {
    background: #f8fafc;
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}
.stat-card-wide {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
}

.stat-num {
    font-size: 2.5rem;
    font-weight: 900;
    font-family: var(--font-heading);
    color: var(--navy);
    line-height: 1;
    letter-spacing: -0.04em;
}
.stat-card-wide .stat-num {
    font-size: 2rem;
    flex-shrink: 0;
    color: var(--accent);
}
.stat-label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--navy-mid);
    line-height: 1.4;
}

.stat-footnote {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    color: var(--muted);
    font-size: 0.82rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.08);
}
.stat-footnote svg {
    flex-shrink: 0;
    margin-top: 1px;
    opacity: 0.8;
}
</style>
