---
const WP_API = import.meta.env.WORDPRESS_API_URL || 'https://lightcoral-spoonbill-227230.hostingersite.com/wp-json/wp/v2';
---

<section class="articles-section">
    <div class="container">
        <div class="section-header">
            <div>
                <span class="section-label">Latest Resources</span>
                <h2>Guides fresh from<br><em>our editorial team</em></h2>
            </div>
            <a href="/blog" class="btn-outline">All articles →</a>
        </div>

        <!-- Loading state -->
        <div id="latest-loading" class="posts-loading">
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
        </div>

        <!-- Posts grid (populated by JS) -->
        <div id="latest-posts" class="posts-grid" style="display:none"></div>

        <!-- Empty state -->
        <div id="latest-empty" class="coming-soon" style="display:none">
            <div class="coming-soon-icon">✍️</div>
            <p class="coming-soon-title">Articles coming soon</p>
            <p>Subscribe to be the first to know.</p>
            <button class="btn-primary mt-4" id="latest-newsletter-trigger">Subscribe free</button>
        </div>
    </div>
</section>

<style>
.articles-section {
    padding: 6rem 0;
    background: var(--light);
}
.section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
}
.section-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.6rem;
}
.section-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--navy);
    line-height: 1.18;
    margin: 0;
}
.section-header h2 em { font-style: normal; color: var(--accent); }
.btn-outline {
    display: inline-block;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--navy);
    padding: 0.65rem 1.25rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 600;
    transition: all var(--transition);
    white-space: nowrap;
}
.btn-outline:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }

/* Skeleton loading */
.posts-loading {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.75rem;
}
.skeleton-card {
    height: 220px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: var(--radius-lg);
}
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

/* Grid */
.posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.75rem;
}

/* Cards */
.post-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.28s ease;
}
.card-top-stripe { height: 4px; transition: height 0.28s ease; }
.post-card:hover { box-shadow: var(--shadow-md); transform: translateY(-6px); border-color: transparent; }
.post-card:hover .card-top-stripe { height: 6px; }
.post-card-body { padding: 1.75rem; display: flex; flex-direction: column; flex-grow: 1; }
.post-card-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
.post-cat-badge {
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.post-date { color: var(--muted); font-size: 0.8rem; }
.post-card h3 { font-size: 1.25rem; margin: 0 0 0.85rem; line-height: 1.3; font-family: var(--font-heading); }
.post-card h3 a { color: var(--navy); transition: color var(--transition); text-decoration: none; }
.post-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.65; margin-bottom: 1.5rem; flex-grow: 1; }
.post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
}
.read-more {
    font-weight: 700;
    font-size: 0.875rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
}
.read-time { font-size: 0.78rem; color: var(--muted); }

/* Coming soon */
.coming-soon {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 2px dashed var(--border);
}
.coming-soon-icon { font-size: 3rem; margin-bottom: 1.25rem; }
.coming-soon-title { font-size: 1.35rem; font-weight: 700; color: var(--navy); margin-bottom: 0.5rem; }
.coming-soon p { color: var(--muted); margin-bottom: 1.75rem; }
.mt-4 { margin-top: 1.5rem; }
</style>

<script>
    const WP_API = 'https://lightcoral-spoonbill-227230.hostingersite.com/wp-json/wp/v2';
    const categoryColors = {
        'employment':           '#0284c7',
        'business-management':  '#7c3aed',
        'compliance':           '#059669',
        'insurance':            '#1e293b',
        'new-technologies':     '#7c3aed',
        'success-stories':      '#f59e0b',
        'failure-stories':      '#e11d48',
    };

    async function loadLatestPosts() {
        try {
            const res = await fetch(`${WP_API}/posts?_embed&per_page=3&status=publish`);
            if (!res.ok) throw new Error('API error');
            const posts = await res.json();

            document.getElementById('latest-loading').style.display = 'none';

            if (!posts.length) {
                document.getElementById('latest-empty').style.display = 'block';
                return;
            }

            const grid = document.getElementById('latest-posts');
            grid.innerHTML = posts.map((post, i) => {
                const category = post._embedded?.['wp:term']?.[0]?.[0]?.slug || 'uncategorized';
                const categoryName = post._embedded?.['wp:term']?.[0]?.[0]?.name || 'Uncategorized';
                const accentColor = categoryColors[category] || '#0284c7';
                const date = new Date(post.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
                const excerpt = post.excerpt.rendered.replace(/(<([^>]+)>)/gi, '').substring(0, 160) + '…';
                return `
                    <article class="post-card" style="animation-delay:${i*0.1}s">
                        <div class="card-top-stripe" style="background:${accentColor}"></div>
                        <div class="post-card-body">
                            <div class="post-card-meta">
                                <span class="post-cat-badge" style="background:${accentColor}20;color:${accentColor}">${categoryName}</span>
                                <span class="post-date">${date}</span>
                            </div>
                            <h3><a href="/blog/${post.slug}">${post.title.rendered}</a></h3>
                            <p>${excerpt}</p>
                            <div class="post-card-footer">
                                <a href="/blog/${post.slug}" class="read-more" style="color:${accentColor}">
                                    Read article
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                </a>
                                <span class="read-time">5 min read</span>
                            </div>
                        </div>
                    </article>`;
            }).join('');
            grid.style.display = 'grid';

        } catch (e) {
            document.getElementById('latest-loading').style.display = 'none';
            document.getElementById('latest-empty').style.display = 'block';
        }
    }

    loadLatestPosts();

    const trigger = document.getElementById('latest-newsletter-trigger');
    const modal = document.getElementById('newsletter-overlay');
    if (trigger && modal) {
        trigger.addEventListener('click', () => {
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
        });
    }
</script>
