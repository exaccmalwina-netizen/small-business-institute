---
/**
 * MailchimpSignupForm — SBI Australia (Astro + vanilla JS, no React)
 *
 * ─── HOW TO CONNECT TO MAILCHIMP ──────────────────────────────────────────
 * 1. Log in to Mailchimp → Audience → Signup Forms → Embedded Forms
 * 2. Copy the "form action" URL, e.g.:
 *      https://yourdomain.us21.list-manage.com/subscribe/post?u=XXXX&id=XXXX
 * 3. Paste it below as MAILCHIMP_ACTION_URL
 *    IMPORTANT: change "/post?" to "/post-json?" so the browser gets JSON back
 * 4. Copy the honeypot field name (b_XXXX_XXXX) and paste as BOT_FIELD_NAME
 * ──────────────────────────────────────────────────────────────────────────
 */

const BOT_FIELD_NAME = "b_acd1587c085debbcd1ae3cb1d_4d0c650865";
---

<section class="sbi-wrap" aria-label="Newsletter signup">
  <!-- idle / error state -->
  <div class="sbi-form-view">
    <span class="sbi-eyebrow">SBI Newsletter</span>
    <h2 class="sbi-h">Stay <em>in the loop.</em></h2>
    <p class="sbi-sub">Only e-mail is required. Provide more details so we pick relevant news for you.</p>

    <form
      id="sbi-mc-form"
      onsubmit="event.preventDefault(); return false;"
      novalidate
    >
      <!-- Mailchimp honeypot — bot protection -->
      <div style="position:absolute;left:-5000px" aria-hidden="true">
        <input type="text" name={BOT_FIELD_NAME} tabindex="-1" value="" autocomplete="off" />
      </div>
      <input type="hidden" name="tags" value="4236977" />

      <!-- 1. EMAIL (FIRST) -->
      <div class="sbi-row">
        <input
          class="sbi-email"
          id="sbi-email-input"
          type="email"
          name="EMAIL"
          placeholder="Your email address *"
          required
          aria-label="Email address"
          autocomplete="email"
        />
      </div>

      <!-- 2. NAME -->
      <div class="sbi-name-row">
        <input
          class="sbi-field"
          id="sbi-fname-input"
          type="text"
          name="FNAME"
          placeholder="First name"
          aria-label="First name"
          autocomplete="given-name"
        />
        <input
          class="sbi-field"
          id="sbi-lname-input"
          type="text"
          name="LNAME"
          placeholder="Last name"
          aria-label="Last name"
          autocomplete="family-name"
        />
      </div>

      <!-- 3. BUSINESS STATUS -->
      <div class="sbi-row">
        <select class="sbi-field sbi-select" name="BUSINESS_STATUS" aria-label="Your Business Status">
          <option value="" disabled selected>Your Business Status</option>
          <option value="Planning to start">Planning to start</option>
          <option value="Growing / planning expansion">Growing / planning expansion</option>
          <option value="Overcoming challenges">Overcoming challenges</option>
          <option value="Steady rolling">Steady rolling</option>
        </select>
      </div>

      <!-- 4. POSTCODE & EMPLOYEES -->
      <div class="sbi-name-row">
        <input
          class="sbi-field"
          id="sbi-postcode-input"
          type="text"
          name="POSTCODE"
          placeholder="Post Code"
          aria-label="Post Code"
        />
        <input
          class="sbi-field"
          id="sbi-employees-input"
          type="number"
          name="EMP_NO"
          placeholder="Number of employees"
          aria-label="Number of employees"
        />
      </div>

      <!-- 5. SUBCONTRACTORS -->
      <div class="sbi-radio-group">
        <span class="sbi-radio-label">Do you use subcontractors?</span>
        <div class="sbi-radio-options">
          <label class="sbi-radio"><input type="radio" name="MMERGE7" value="Frequently"> Frequently</label>
          <label class="sbi-radio"><input type="radio" name="MMERGE7" value="Sometimes"> Sometimes</label>
          <label class="sbi-radio"><input type="radio" name="MMERGE7" value="Never"> Never</label>
        </div>
      </div>

      <!-- 6. INDUSTRY -->
      <div class="sbi-row">
        <input
          class="sbi-field"
          id="sbi-industry-input"
          type="text"
          name="INDUSTRY"
          placeholder="What is your industry / services you provide?"
          aria-label="Industry / Services"
        />
      </div>

      <!-- 7. SUBMIT BUTTON -->
      <div class="sbi-row">
        <button class="sbi-btn sbi-btn-full" id="sbi-submit-btn" type="submit">
          Subscribe free
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <path d="M2.5 7.5h10M9 3.5l4 4-4 4" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <p class="sbi-error" id="sbi-error" role="alert" style="display:none"></p>

      <p class="sbi-privacy">
        <span class="sbi-privacy-dot"></span>
        No spam. Maintained in Australia. Unsubscribe anytime.
      </p>
    </form>
  </div>

  <!-- success state (hidden by default) -->
  <div class="sbi-ok" id="sbi-success" style="display:none" aria-live="polite">
    <span class="sbi-ok-icon">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.5"/>
        <path d="M7 11.5l2.8 2.8 5-5.6" stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <div>
      <h3>You're in!</h3>
      <p>Welcome to the SBI community. Your first issue is on its way.</p>
    </div>
  </div>
</section>

<style>
@keyframes sbi-spin   { to { transform: rotate(360deg); } }
@keyframes sbi-appear { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

.sbi-wrap {
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  background: var(--white, #ffffff);
  border: 1px solid var(--border, #e2e8f0);
  border-radius: var(--radius-lg, 20px);
  padding: 44px 44px 36px;
  max-width: 500px;
  width: 100%;
  animation: sbi-appear .3s ease both;
  box-sizing: border-box;
  box-shadow: var(--shadow-md);
}

.sbi-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--accent, #0284c7);
  margin-bottom: 14px;
}
.sbi-eyebrow::before {
  content: '';
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent, #0284c7);
  opacity: .7;
}

.sbi-h {
  font-family: var(--font-heading, 'Sora', 'Inter', system-ui, sans-serif);
  font-size: 28px;
  font-weight: 800;
  line-height: 1.15;
  color: var(--navy, #0f172a);
  margin: 0 0 10px;
  letter-spacing: -0.02em;
}
.sbi-h em {
  font-style: normal;
  background: linear-gradient(135deg, var(--accent, #0284c7), #0369a1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sbi-sub {
  font-size: 14.5px;
  line-height: 1.6;
  color: var(--navy-mid, #475569);
  margin: 0 0 24px;
}

.sbi-name-row {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
}

.sbi-row {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
}

.sbi-radio-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 16px;
  text-align: left;
}
.sbi-radio-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--navy, #0f172a);
}
.sbi-radio-options {
  display: flex;
  gap: 16px;
  margin-bottom: 4px;
}
.sbi-radio {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  color: var(--navy, #0f172a);
  cursor: pointer;
}
.sbi-radio input[type="radio"] {
  accent-color: var(--accent, #0284c7);
  width: 16px;
  height: 16px;
  margin: 0;
  cursor: pointer;
}

.sbi-field {
  flex: 1;
  height: 48px;
  padding: 0 16px;
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  font-size: 14px;
  color: var(--navy, #0f172a);
  background: var(--white, #fff); /* Force white so it doesn't look disabled */
  border: 1px solid var(--border, #cbd5e1);
  border-radius: var(--radius, 10px);
  outline: none;
  transition: border-color .15s, box-shadow .15s;
  min-width: 0;
  box-shadow: 0 1px 2px rgba(0,0,0,0.02);
}
.sbi-field::placeholder { color: var(--muted, #64748b); opacity: 0.8; }
.sbi-field:focus {
  border-color: var(--accent, #0284c7);
  box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.12);
}
.sbi-field:disabled { opacity: .55; background: #f1f5f9; }

.sbi-select {
  appearance: none;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  background-repeat: no-repeat;
  background-position: right 14px center;
  background-size: 16px;
  padding-right: 40px;
}
.sbi-select:invalid { color: var(--muted); }

.sbi-email {
  flex: 1;
  height: 48px;
  padding: 0 16px;
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  font-size: 14.5px;
  color: var(--navy, #0f172a);
  background: var(--white, #fff);
  border: 1px solid var(--border, #cbd5e1);
  border-radius: var(--radius, 10px);
  outline: none;
  transition: border-color .15s, box-shadow .15s;
  box-shadow: 0 1px 2px rgba(0,0,0,0.02);
}
.sbi-email::placeholder { color: var(--muted, #64748b); opacity: 0.8; }
.sbi-email:focus {
  border-color: var(--accent, #0284c7);
  box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.12);
}
.sbi-email:disabled { opacity: .55; background: #f1f5f9; }

.sbi-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 46px;
  padding: 0 22px;
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  background: var(--accent, #0284c7);
  border: none;
  border-radius: var(--radius, 10px);
  cursor: pointer;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(2, 132, 199, 0.3);
  transition: background .15s, transform .1s, box-shadow .15s;
  letter-spacing: 0.01em;
}
.sbi-btn-full {
  width: 100%;
  justify-content: center;
  height: 50px;
}
.sbi-btn:hover  {
  background: var(--accent-dark, #0369a1);
  box-shadow: 0 6px 20px rgba(2, 132, 199, 0.4);
  transform: translateY(-1px);
}
.sbi-btn:active { transform: scale(.97); }
.sbi-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }

.sbi-spinner {
  width: 17px; height: 17px;
  border: 2px solid rgba(255,255,255,.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: sbi-spin .75s linear infinite;
}

.sbi-error {
  margin-top: 9px;
  font-size: 12.5px;
  color: var(--rose, #e11d48);
  animation: sbi-appear .2s ease;
}

.sbi-privacy {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-top: 14px;
  font-size: 12px;
  color: var(--muted, #64748b);
}
.sbi-privacy-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--accent, #0284c7);
  flex-shrink: 0;
  opacity: 0.5;
}

.sbi-ok {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  animation: sbi-appear .3s ease;
}
.sbi-ok-icon {
  color: var(--emerald, #059669);
  margin-top: 2px;
  flex-shrink: 0;
  background: rgba(5, 150, 105, 0.1);
  border-radius: 50%;
  padding: 4px;
}
.sbi-ok h3 {
  font-family: var(--font-heading, 'Sora', system-ui, sans-serif);
  font-size: 22px;
  font-weight: 800;
  color: var(--navy, #0f172a);
  margin: 0 0 5px;
  letter-spacing: -0.02em;
}
.sbi-ok p { font-size: 14px; color: var(--muted, #64748b); margin: 0; line-height: 1.6; }
</style>

<script>
  document.addEventListener('submit', async (e) => {
    const form = e.target;
    if (!form || form.id !== 'sbi-mc-form') return;
    
    e.preventDefault(); // Stop native submission

    const emailInput = document.getElementById('sbi-email-input');
    const errorEl    = document.getElementById('sbi-error');
    const successEl  = document.getElementById('sbi-success');
    const formView   = document.querySelector('.sbi-form-view');
    const submitBtn  = document.getElementById('sbi-submit-btn');

    if (errorEl) errorEl.style.display = 'none';

    const email = emailInput?.value.trim() ?? '';
    if (!email) {
      if (errorEl) { errorEl.textContent = 'Please enter your email address.'; errorEl.style.display = 'block'; }
      return;
    }

    // Prepare JSON Payload
    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    // Switch to loading UI safely
    let originalBtnHTML = '';
    if (submitBtn) {
      originalBtnHTML = submitBtn.innerHTML;
      submitBtn.innerHTML = '<div class="sbi-spinner"></div>';
      submitBtn.disabled = true;
    }

    try {
      const response = await fetch('/api/subscribe.php', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        throw new Error('API Error: ' + response.status);
      }

      // Hide form, show success state inline
      if (formView) formView.style.display = 'none';
      if (successEl) successEl.style.display = 'flex';

    } catch (err) {
      console.error('Newsletter Signup Error:', err);
      if (errorEl) {
        errorEl.textContent = 'Sorry, there was an error processing your request. Please try again.';
        errorEl.style.display = 'block';
      }
    } finally {
      // Revert loading UI
      if (submitBtn) {
        submitBtn.innerHTML = originalBtnHTML;
        submitBtn.disabled = false;
      }
    }
  });
</script>
