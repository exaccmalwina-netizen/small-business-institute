---
/**
 * MailchimpSignupForm — SBI Australia (Astro + vanilla JS, no React)
 *
 * ─── HOW TO CONNECT TO MAILCHIMP ──────────────────────────────────────────
 * 1. Log in to Mailchimp → Audience → Signup Forms → Embedded Forms
 * 2. Copy the "form action" URL, e.g.:
 *      https://yourdomain.us21.list-manage.com/subscribe/post?u=XXXX&id=XXXX
 * 3. Paste it below as MAILCHIMP_ACTION_URL
 *    IMPORTANT: change "/post?" to "/post-json?" so the browser gets JSON back
 * 4. Copy the honeypot field name (b_XXXX_XXXX) and paste as BOT_FIELD_NAME
 * ──────────────────────────────────────────────────────────────────────────
 */

const BOT_FIELD_NAME = "b_acd1587c085debbcd1ae3cb1d_4d0c650865";
---

<section class="sbi-wrap" aria-label="Newsletter signup">
  <!-- idle / error state -->
  <div class="sbi-form-view">
    <span class="sbi-eyebrow">SBI Newsletter</span>
    <h2 class="sbi-h">Stay <em>in the know.</em></h2>
    <p class="sbi-sub">Practical guides, compliance updates and real business insights — straight to your inbox.</p>

    <form
      id="sbi-mc-form"
      action="https://btmh.us20.list-manage.com/subscribe/post?u=acd1587c085debbcd1ae3cb1d&amp;id=4d0c650865&amp;f_id=0061caf1f0"
      method="post"
      target="_blank"
      novalidate
    >
      <!-- Mailchimp honeypot — bot protection -->
      <div style="position:absolute;left:-5000px" aria-hidden="true">
        <input type="text" name={BOT_FIELD_NAME} tabindex="-1" value="" autocomplete="off" />
      </div>
      <input type="hidden" name="tags" value="4236977" />

      <div class="sbi-name-row">
        <input
          class="sbi-field"
          id="sbi-fname-input"
          type="text"
          name="FNAME"
          placeholder="First name"
          aria-label="First name"
          autocomplete="given-name"
        />
        <input
          class="sbi-field"
          id="sbi-lname-input"
          type="text"
          name="LNAME"
          placeholder="Last name"
          aria-label="Last name"
          autocomplete="family-name"
        />
      </div>

      <div class="sbi-name-row">
        <input
          class="sbi-field"
          id="sbi-postcode-input"
          type="text"
          name="POSTCODE"
          placeholder="Post Code"
          aria-label="Post Code"
        />
        <input
          class="sbi-field"
          id="sbi-employees-input"
          type="number"
          name="EMP_NO"
          placeholder="Number of employees"
          aria-label="Number of employees"
        />
      </div>

      <div class="sbi-radio-group">
        <span class="sbi-radio-label">Do you use subcontractors?</span>
        <div class="sbi-radio-options">
          <label class="sbi-radio"><input type="radio" name="MMERGE7" value="Frequently"> Frequently</label>
          <label class="sbi-radio"><input type="radio" name="MMERGE7" value="Sometimes"> Sometimes</label>
          <label class="sbi-radio"><input type="radio" name="MMERGE7" value="Never"> Never</label>
        </div>
      </div>

      <div class="sbi-row" style="margin-bottom:8px">
        <input
          class="sbi-field"
          id="sbi-industry-input"
          type="text"
          name="INDUSTRY"
          placeholder="What is your industry / services you provide?"
          aria-label="Industry / Services"
        />
      </div>

      <div class="sbi-row">
        <input
          class="sbi-email"
          id="sbi-email-input"
          type="email"
          name="EMAIL"
          placeholder="Your email address"
          required
          aria-label="Email address"
          autocomplete="email"
        />
        <button class="sbi-btn" id="sbi-submit-btn" type="submit">
          Subscribe free
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <path d="M2.5 7.5h10M9 3.5l4 4-4 4" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <p class="sbi-error" id="sbi-error" role="alert" style="display:none"></p>

      <p class="sbi-privacy">
        <span class="sbi-privacy-dot"></span>
        No spam. Unsubscribe anytime.
      </p>
    </form>
  </div>

  <!-- success state (hidden by default) -->
  <div class="sbi-ok" id="sbi-success" style="display:none" aria-live="polite">
    <span class="sbi-ok-icon">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="10" stroke="currentColor" stroke-width="1.5"/>
        <path d="M7 11.5l2.8 2.8 5-5.6" stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <div>
      <h3>You're in!</h3>
      <p>Welcome to the SBI community. Your first issue is on its way.</p>
    </div>
  </div>
</section>

<style>
@keyframes sbi-spin   { to { transform: rotate(360deg); } }
@keyframes sbi-appear { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

.sbi-wrap {
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  background: var(--white, #ffffff);
  border: 1px solid var(--border, #e2e8f0);
  border-radius: var(--radius-lg, 20px);
  padding: 44px 44px 36px;
  max-width: 500px;
  width: 100%;
  animation: sbi-appear .3s ease both;
  box-sizing: border-box;
  box-shadow: var(--shadow-md);
}

.sbi-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--accent, #0284c7);
  margin-bottom: 14px;
}
.sbi-eyebrow::before {
  content: '';
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent, #0284c7);
  opacity: .7;
}

.sbi-h {
  font-family: var(--font-heading, 'Sora', 'Inter', system-ui, sans-serif);
  font-size: 28px;
  font-weight: 800;
  line-height: 1.15;
  color: var(--navy, #0f172a);
  margin: 0 0 10px;
  letter-spacing: -0.02em;
}
.sbi-h em {
  font-style: normal;
  background: linear-gradient(135deg, var(--accent, #0284c7), #0369a1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sbi-sub {
  font-size: 14px;
  line-height: 1.65;
  color: var(--muted, #64748b);
  margin: 0 0 28px;
}

.sbi-name-row {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
}

.sbi-row {
  display: flex;
  gap: 8px;
}

.sbi-radio-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 12px;
  text-align: left;
}
.sbi-radio-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--navy, #0f172a);
}
.sbi-radio-options {
  display: flex;
  gap: 16px;
  margin-bottom: 4px;
}
.sbi-radio {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  color: var(--navy, #0f172a);
  cursor: pointer;
}
.sbi-radio input[type="radio"] {
  accent-color: var(--accent, #0284c7);
  width: 16px;
  height: 16px;
  margin: 0;
  cursor: pointer;
}

.sbi-field {
  flex: 1;
  height: 46px;
  padding: 0 16px;
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  font-size: 14px;
  color: var(--navy, #0f172a);
  background: var(--off-white, #f8fafc);
  border: 1.5px solid var(--border, #e2e8f0);
  border-radius: var(--radius, 10px);
  outline: none;
  transition: border-color .15s, box-shadow .15s, background .15s;
  min-width: 0;
}
.sbi-field::placeholder { color: var(--muted, #64748b); opacity: 0.6; }
.sbi-field:focus {
  border-color: var(--accent, #0284c7);
  background: var(--white, #fff);
  box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.12);
}
.sbi-field:disabled { opacity: .55; }

.sbi-email {
  flex: 1;
  height: 46px;
  padding: 0 16px;
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  font-size: 14px;
  color: var(--navy, #0f172a);
  background: var(--off-white, #f8fafc);
  border: 1.5px solid var(--border, #e2e8f0);
  border-radius: var(--radius, 10px);
  outline: none;
  transition: border-color .15s, box-shadow .15s, background .15s;
}
.sbi-email::placeholder { color: var(--muted, #64748b); opacity: 0.6; }
.sbi-email:focus {
  border-color: var(--accent, #0284c7);
  background: var(--white, #fff);
  box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.12);
}
.sbi-email:disabled { opacity: .55; }

.sbi-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 46px;
  padding: 0 22px;
  font-family: var(--font-body, 'Inter', system-ui, sans-serif);
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  background: var(--accent, #0284c7);
  border: none;
  border-radius: var(--radius, 10px);
  cursor: pointer;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(2, 132, 199, 0.3);
  transition: background .15s, transform .1s, box-shadow .15s;
  letter-spacing: 0.01em;
}
.sbi-btn:hover  {
  background: var(--accent-dark, #0369a1);
  box-shadow: 0 6px 20px rgba(2, 132, 199, 0.4);
  transform: translateY(-1px);
}
.sbi-btn:active { transform: scale(.97); }
.sbi-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }

.sbi-spinner {
  width: 17px; height: 17px;
  border: 2px solid rgba(255,255,255,.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: sbi-spin .75s linear infinite;
}

.sbi-error {
  margin-top: 9px;
  font-size: 12.5px;
  color: var(--rose, #e11d48);
  animation: sbi-appear .2s ease;
}

.sbi-privacy {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-top: 14px;
  font-size: 12px;
  color: var(--muted, #64748b);
}
.sbi-privacy-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--accent, #0284c7);
  flex-shrink: 0;
  opacity: 0.5;
}

.sbi-ok {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  animation: sbi-appear .3s ease;
}
.sbi-ok-icon {
  color: var(--emerald, #059669);
  margin-top: 2px;
  flex-shrink: 0;
  background: rgba(5, 150, 105, 0.1);
  border-radius: 50%;
  padding: 4px;
}
.sbi-ok h3 {
  font-family: var(--font-heading, 'Sora', system-ui, sans-serif);
  font-size: 22px;
  font-weight: 800;
  color: var(--navy, #0f172a);
  margin: 0 0 5px;
  letter-spacing: -0.02em;
}
.sbi-ok p { font-size: 14px; color: var(--muted, #64748b); margin: 0; line-height: 1.6; }
</style>

<script>
  // On form submit: validate email, then let the native POST go through
  // (form action points to Mailchimp, target="_blank" opens in new tab).
  // Immediately show the success state in the modal.
  document.addEventListener('submit', (e) => {
    const form = e.target as HTMLFormElement;
    if (form.id !== 'sbi-mc-form') return;

    const emailInput = document.getElementById('sbi-email-input') as HTMLInputElement | null;
    const errorEl    = document.getElementById('sbi-error')       as HTMLElement | null;
    const successEl  = document.getElementById('sbi-success')     as HTMLElement | null;
    const formView   = document.querySelector('.sbi-form-view')   as HTMLElement | null;

    const email = emailInput?.value.trim() ?? '';
    if (!email) {
      e.preventDefault();
      if (errorEl) { errorEl.textContent = 'Please enter your email address.'; errorEl.style.display = 'block'; }
      return;
    }

    // Let the form POST go to Mailchimp in a new tab, show success inline
    if (formView) formView.style.display = 'none';
    if (successEl) successEl.style.display = 'flex';
  });
</script>
