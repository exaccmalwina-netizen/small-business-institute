---

<section class="guides-section">
    <div class="container">
        <div class="section-header">
            <div>
                <span class="section-label">Browse by topic</span>
            </div>
            <a href="/blog" class="btn-outline">View all articles →</a>
        </div>
        <div class="guides-grid">
            {guides.map((guide, i) => (
                <a 
                    href={`/blog?cat=${guide.id}`} 
                    class="guide-card reveal"
                    style={`--card-color: ${guide.color}; --card-bg: ${guide.bg}; animation-delay: ${i * 0.07}s`}
                >
                    <div class="card-icon-wrap">
                        <span class="guide-icon" set:html={guide.svg}></span>
                    </div>
                    <div class="card-content">
                        <h4>{guide.name}</h4>
                        <p>{guide.desc}</p>
                    </div>
                    <span class="card-arrow">→</span>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
.guides-section {
    padding: 6rem 0;
    background: var(--white);
    position: relative;
    overflow: hidden;
}
.guides-section::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(2,132,199,0.06) 0%, transparent 70%);
    pointer-events: none;
}

.section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
}
.section-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.6rem;
}
.section-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--navy);
    line-height: 1.18;
    margin: 0;
}
.section-header h2 em {
    font-style: normal;
    color: var(--accent);
}

.btn-outline {
    display: inline-block;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--navy);
    padding: 0.65rem 1.25rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 600;
    transition: all var(--transition);
    white-space: nowrap;
}
.btn-outline:hover {
    background: var(--navy);
    color: var(--white);
    border-color: var(--navy);
}

/* Grid */
.guides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.25rem;
}

/* Card */
.guide-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.4rem 1.5rem;
    background: var(--off-white);
    border-radius: var(--radius-lg);
    border: 1.5px solid transparent;
    transition: all 0.25s ease;
    color: inherit;
    text-decoration: none;
    position: relative;
    overflow: hidden;
}
.guide-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--card-bg);
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 0;
}
.guide-card:hover {
    border-color: var(--card-color);
    box-shadow: 0 8px 28px rgba(0,0,0,0.09);
    transform: translateY(-3px);
}
.guide-card:hover::before {
    opacity: 1;
}
.guide-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--card-color);
}
.card-icon-wrap {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: var(--card-bg);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    transition: background 0.25s ease;
}
.guide-card:hover .card-icon-wrap {
    background: white;
}
.guide-icon {
    width: 24px;
    height: 24px;
    color: var(--card-color);
    display: block;
}
.card-content {
    flex: 1;
    position: relative;
    z-index: 1;
}
.guide-card h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy);
    margin: 0 0 0.3rem;
    font-family: var(--font-body);
}
.guide-card p {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.45;
    margin: 0;
}
.card-arrow {
    font-size: 1.1rem;
    color: var(--muted);
    opacity: 0;
    transform: translateX(-6px);
    transition: all 0.25s ease;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
}
</style>
