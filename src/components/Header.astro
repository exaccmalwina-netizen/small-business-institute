---
---

<header class="site-header">
    <div class="container header-inner">
        <!-- Logo -->
        <a href="/" class="logo" aria-label="Small Business Institute Home">
            <svg class="logo-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="40" height="40" rx="9" fill="#0284c7"/>
                <text x="20" y="28" text-anchor="middle" font-family="'Sora', 'Inter', sans-serif" font-size="22" font-weight="800" fill="white" letter-spacing="-1">S</text>
            </svg>
            <div class="logo-text-wrap">
                <span class="logo-name">Small Business Institute <span class="logo-name-desktop">of Australia</span></span>
            </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="site-nav">
            <a href="/blog" class="nav-link">Resources</a>
            <a href="/about" class="nav-link">About Us</a>
            <a href="/contact" class="nav-link">Contact</a>
            <button class="btn-primary" id="header-join-trigger">Join SBI</button>
        </nav>

        <!-- Mobile Menu Toggle -->
        <button class="menu-toggle" id="menu-toggle" aria-label="Open Menu" aria-expanded="false">
            <div class="burger-box">
                <div class="burger-inner"></div>
            </div>
        </button>
    </div>

    <!-- Mobile Navigation Overlay (Redesigned) -->
    <div class="mobile-overlay" id="mobile-nav" aria-hidden="true">
        <div class="mobile-overlay-bg"></div>
        <div class="mobile-overlay-content">
            <nav class="mobile-menu-list">
                <a href="/" class="mobile-nav-item">
                    <span class="m-nav-label">Home</span>
                    <span class="m-nav-sub">Return home</span>
                </a>
                <a href="/blog" class="mobile-nav-item">
                    <span class="m-nav-label">Resources</span>
                    <span class="m-nav-sub">News & Stories</span>
                </a>
                <a href="/about" class="mobile-nav-item">
                    <span class="m-nav-label">About Us</span>
                    <span class="m-nav-sub">Who we are</span>
                </a>
                <a href="/contact" class="mobile-nav-item">
                    <span class="m-nav-label">Contact</span>
                    <span class="m-nav-sub">Get in touch</span>
                </a>
            </nav>
            <div class="mobile-overlay-footer">
                <button class="btn-primary" id="mobile-join-trigger" style="width: 100%; justify-content: center; padding: 1.2rem;">Join the Community</button>
            </div>
        </div>
    </div>
</header>

<style>
.site-header {
    position: sticky;
    top: 0;
    z-index: 999;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border);
    height: 72px;
    display: flex;
    align-items: center;
}
.header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    z-index: 1001;
}
.logo-icon { width: 36px; height: 36px; }
.logo-name {
    font-size: 0.825rem;
    @media (min-width: 400px) { font-size: 0.95rem; }
    font-weight: 800;
    color: var(--navy);
    font-family: var(--font-heading);
}
.logo-name-desktop { display: none; }
@media (min-width: 640px) { .logo-name-desktop { display: inline; } }

/* Desktop Navigation */
.site-nav {
    display: none;
    align-items: center;
    gap: 2rem;
}
@media (min-width: 1024px) { .site-nav { display: flex; } }
.nav-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--navy);
}

/* Mobile Toggle (Burger) */
.menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 1001;
    transition: transform 0.3s ease;
}
@media (min-width: 1024px) { .menu-toggle { display: none; } }

.burger-box { width: 24px; height: 18px; position: relative; }
.burger-inner, .burger-inner::before, .burger-inner::after {
    width: 24px;
    height: 2px;
    background-color: var(--navy);
    position: absolute;
    transition: transform 0.3s cubic-bezier(0.68, -0.6, 0.32, 1.6);
    border-radius: 4px;
}
.burger-inner { top: 50%; transform: translateY(-50%); }
.burger-inner::before { content: ""; top: -8px; }
.burger-inner::after { content: ""; top: 8px; }

/* Hamburger Active State */
.menu-toggle.active .burger-inner { background-color: transparent; }
.menu-toggle.active .burger-inner::before { transform: translateY(8px) rotate(45deg); }
.menu-toggle.active .burger-inner::after { transform: translateY(-8px) rotate(-45deg); }

/* MOBILE OVERLAY REDESIGN */
.mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    z-index: 1000;
    visibility: hidden;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}
.mobile-overlay.active { visibility: visible; }

.mobile-overlay-bg {
    position: absolute;
    inset: 0;
    background: var(--navy);
    opacity: 0;
    transition: opacity 0.5s ease;
}
.mobile-overlay.active .mobile-overlay-bg { opacity: 0.98; }

.mobile-overlay-content {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.mobile-overlay.active .mobile-overlay-content { opacity: 1; transform: translateY(0); }

.mobile-menu-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}
.mobile-nav-item {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 0;
    text-decoration: none;
}
.m-nav-label {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--white);
    line-height: 1.1;
}
.m-nav-sub {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
}

.mobile-overlay-footer {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
}
</style>

<script>
    const toggle = document.getElementById('menu-toggle');
    const nav = document.getElementById('mobile-nav');
    const triggers = ['header-join-trigger', 'mobile-join-trigger'];
    const newsletter = document.getElementById('newsletter-overlay');

    function toggleMenu() {
        const isOpen = nav.classList.toggle('active');
        toggle.classList.toggle('active');
        document.body.style.overflow = isOpen ? 'hidden' : '';
        nav.setAttribute('aria-hidden', (!isOpen).toString());
    }

    if (toggle && nav) {
        toggle.addEventListener('click', toggleMenu);
        
        // Close on link click
        nav.querySelectorAll('.mobile-nav-item').forEach(link => {
            link.addEventListener('click', toggleMenu);
        });
    }

    // Modal triggers integration
    triggers.forEach(id => {
        const el = document.getElementById(id);
        if (el && newsletter) {
            el.addEventListener('click', () => {
                newsletter.style.display = 'flex';
                newsletter.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
                if (nav.classList.contains('active')) toggleMenu();
            });
        }
    });

</script>

