<section class="hero-section" id="hero">
  <!-- Floating profession images (parallax layer) -->
  <div class="floating-images" id="floating-container" aria-hidden="true">

    <!-- Left side images -->
    <div class="float-el" data-depth="0.7" style="top: 18%; left: 2%;">
      <img
        src="https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=320&q=80&auto=format&fit=crop"
        alt="Electrician at work"
        class="float-img float-img--sm float-img--tilt-neg animate-float-1"
      />
    </div>

    <div class="float-el" data-depth="1.8" style="top: 2%; left: 10%;">
      <img
        src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=420&q=80&auto=format&fit=crop"
        alt="Construction worker on site"
        class="float-img float-img--md float-img--tilt-neg-lg animate-float-2"
      />
    </div>

    <div class="float-el" data-depth="3.5" style="top: 72%; left: 5%;">
      <img
        src="https://images.unsplash.com/photo-1606787366850-de6330128bfc?w=380&q=80&auto=format&fit=crop"
        alt="Chef cooking in kitchen"
        class="float-img float-img--lg float-img--tilt-neg-sm animate-float-3"
      />
    </div>

    <!-- Right side images -->
    <div class="float-el" data-depth="1.2" style="top: 1%; left: 82%;">
      <img
        src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=400&q=80&auto=format&fit=crop"
        alt="Hairdresser styling hair"
        class="float-img float-img--md float-img--tilt-pos animate-float-2"
      />
    </div>

    <div class="float-el" data-depth="2.5" style="top: 68%; left: 80%;">
      <img
        src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=400&q=80&auto=format&fit=crop"
        alt="Plumber fixing pipes"
        class="float-img float-img--lg float-img--tilt-pos-lg animate-float-1"
      />
    </div>

    <div class="float-el" data-depth="0.9" style="top: 40%; left: 88%;">
      <img
        src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=300&q=80&auto=format&fit=crop"
        alt="Accountant working at desk"
        class="float-img float-img--sm float-img--tilt-neg-sm animate-float-3"
      />
    </div>

  </div>

  <!-- Hero Content -->
  <div class="hero-body">
    <!-- Proof bar -->
    <div class="hero-proof reveal reveal-delay-1">
      <div class="avatar-stack">
        <div class="avatar"><img src="/assets/images/avatar_1.jpg" alt="Member" /></div>
        <div class="avatar"><img src="/assets/images/avatar_2.jpg" alt="Member" /></div>
        <div class="avatar"><img src="/assets/images/avatar_3.jpg" alt="Member" /></div>
        <div class="avatar"><img src="/assets/images/avatar_4.jpg" alt="Member" /></div>
        <div class="avatar"><img src="/assets/images/avatar_5.jpg" alt="Member" /></div>
      </div>
      <span class="proof-text">Trusted by 200+ Australian Businesses</span>
    </div>

    <!-- Headline with rotating word -->
    <h1 class="hero-headline reveal reveal-delay-2">
      <span>Supporting Small</span>
      <span>Business to</span>
      <span class="headline-row">
        <span class="inline-text">become</span>
        <span class="rotate-wrapper" aria-live="polite">
          <span class="rotate-track" id="rotate-track">
            <!-- Words injected by JS -->
          </span>
        </span>
      </span>
    </h1>

    <p class="hero-sub reveal reveal-delay-3">
      We gather news, insights, analyses and stories, and share them with all small business decision makers.
    </p>

    <button
      id="hero-template-trigger"
      class="btn-hero reveal reveal-delay-4"
      aria-label="Join the Community"
    >
      Join the Community
      <span class="btn-hero-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </span>
    </button>

    <p class="hero-tagline reveal reveal-delay-5">
      The Knowledge Base for Small Business decision makers.
    </p>
  </div>
</section>

<style>
/* ======================================
   HERO SECTION — floating images + text rotate
   ====================================== */
.hero-section {
  position: relative;
  min-height: calc(100vh - 68px);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--off-white);
}

/* ---- Floating image layer ---- */
.floating-images {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.float-el {
  position: absolute;
  will-change: transform;
}

.float-img {
  display: block;
  object-fit: cover;
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 6px 20px rgba(0,0,0,0.10);
  transition: transform 0.2s ease;
}
.float-img:hover { transform: scale(1.04); }

/* --- Idle Floating Animations --- */
.animate-float-1 { animation: float-bob 6s ease-in-out infinite; }
.animate-float-2 { animation: float-bob 8s ease-in-out infinite reverse; }
.animate-float-3 { animation: float-bob 7s ease-in-out infinite 1s; }

@keyframes float-bob {
  0%, 100% { transform: translateY(0) rotate(0); }
  50% { transform: translateY(-15px) rotate(2deg); }
}

/* Sizes */
.float-img--sm  { width: 120px;  height: 90px;  }
.float-img--md  { width: 200px;  height: 150px; }
.float-img--lg  { width: 230px;  height: 230px; }

@media (min-width: 768px) {
  .float-img--sm  { width: 150px;  height: 110px;  }
  .float-img--md  { width: 240px;  height: 180px; }
  .float-img--lg  { width: 280px;  height: 280px; }
}

/* Tilts (applied via margin to not conflict with animation) */
.float-img--tilt-neg     { margin-top: 0; }
.float-img--tilt-neg-sm  { margin-top: 0; }
.float-img--tilt-neg-lg  { margin-top: 0; }
.float-img--tilt-pos     { margin-top: 0; }
.float-img--tilt-pos-lg  { margin-top: 0; }

/* Fade-in animation on load */
.float-el { opacity: 0; animation: floatFadeIn 0.6s ease forwards; }
.float-el:nth-child(1) { animation-delay: 0.5s; }
.float-el:nth-child(2) { animation-delay: 0.7s; }
.float-el:nth-child(3) { animation-delay: 0.9s; }
.float-el:nth-child(4) { animation-delay: 1.1s; }
.float-el:nth-child(5) { animation-delay: 1.3s; }
.float-el:nth-child(6) { animation-delay: 1.5s; }

@keyframes floatFadeIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ---- Hero body (centered) ---- */
.hero-body {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.5rem;
  max-width: 680px;
  padding: 3rem 1.5rem;
}

/* Proof bar */
.hero-proof {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}
.avatar-stack { display: flex; margin-left: 0.5rem; }
.avatar {
  width: 2.75rem;
  height: 2.75rem;
  border-radius: 50%;
  border: 2px solid var(--white);
  margin-left: -0.65rem;
  overflow: hidden;
  box-shadow: var(--shadow);
}
.avatar img { width: 100%; height: 100%; object-fit: cover; }
.proof-text {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--navy-mid);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* ---- Headline ---- */
.hero-headline {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: clamp(2.4rem, 5.5vw, 4.2rem);
  color: var(--navy);
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15em;
}

/* Row with inline text + rotating word */
.headline-row {
  display: flex;
  align-items: center;
  gap: 0.28em;
  flex-wrap: nowrap;
  white-space: nowrap;
}
.inline-text { display: inline-block; }

/* ---- Text Rotator ---- */
.rotate-wrapper {
  display: inline-block;
  overflow: hidden;
  vertical-align: bottom;
  /* Smoother 'Easy Ease' curve */
  transition: width 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: width;
}

.rotate-track {
  display: flex;
  flex-direction: column;
  will-change: transform;
}

.rotate-word {
  display: block;
  color: var(--accent);
  line-height: 1.12;
  white-space: nowrap;
  /* Each word occupies exactly 1 line-height slot */
  height: 1.12em;
  overflow: hidden;
}

/* character-level spans set by JS */
.rotate-char {
  display: inline-block;
  will-change: transform, opacity;
}

/* ---- Subheadline ---- */
.hero-sub {
  font-size: clamp(1rem, 2.2vw, 1.25rem);
  color: var(--muted);
  line-height: 1.65;
  max-width: 540px;
  margin: 0;
}

/* ---- CTA Button ---- */
.btn-hero {
  display: inline-flex;
  align-items: center;
  background: var(--navy);
  color: var(--white);
  font-size: 1.05rem;
  font-weight: 600;
  font-family: var(--font-body);
  border: none;
  padding: 0 0 0 1.5rem;
  cursor: pointer;
  border-radius: 100px;
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: background 0.25s ease, transform 0.2s ease;
}
.btn-hero:hover {
  background: var(--accent);
  transform: translateY(-2px);
}
.btn-hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.85rem 1rem;
  margin-left: 1.25rem;
  border-left: 1px solid rgba(255,255,255,0.2);
  background: rgba(0,0,0,0.12);
}

/* ---- Tagline ---- */
.hero-tagline {
  font-size: 0.875rem;
  color: var(--muted);
  font-style: italic;
  margin: 0;
}

/* --- Mobile: hide side images on very small screens --- */
@media (max-width: 639px) {
  .float-el:nth-child(1),
  .float-el:nth-child(2),
  .float-el:nth-child(3),
  .float-el:nth-child(4),
  .float-el:nth-child(5),
  .float-el:nth-child(6) {
    display: none;
  }
  .hero-body { padding: 4rem 1rem; }
}
@media (max-width: 900px) {
  .float-img--lg { width: 180px; height: 180px; }
  .float-img--md { width: 150px; height: 110px; }
  .float-img--sm { width: 100px; height: 75px; }
}

/* reveal helper (from global.css) */
.reveal { opacity: 0; animation: fadeUp 0.6s ease forwards; }
.reveal-delay-1 { animation-delay: 0.2s; }
.reveal-delay-2 { animation-delay: 0.35s; }
.reveal-delay-3 { animation-delay: 0.5s; }
.reveal-delay-4 { animation-delay: 0.65s; }
.reveal-delay-5 { animation-delay: 0.8s; }
</style>

<script type="module">
/* =============================================
   HERO INTERACTIONS
   1. Parallax floating images (mouse-follow)
   2. Animated text rotator (character-level)
   ============================================= */

/* ---- 1. PARALLAX ---- */
(function initParallax() {
  const container = document.getElementById('floating-container');
  if (!container) return;

  const els = Array.from(container.querySelectorAll('.float-el'));
  const positions = els.map(() => ({ x: 0, y: 0 }));
  let mouse = { x: 0, y: 0 };
  let targetMouse = { x: 0, y: 0 };

  window.addEventListener('mousemove', (e) => {
    // Normalized position from -1 to 1 based on window size
    targetMouse.x = (e.clientX / window.innerWidth - 0.5) * 2;
    targetMouse.y = (e.clientY / window.innerHeight - 0.5) * 2;
  });

  function tick() {
    // Smoother liquid feel
    mouse.x += (targetMouse.x - mouse.x) * 0.04;
    mouse.y += (targetMouse.y - mouse.y) * 0.04;

    els.forEach((el, i) => {
      const depth = parseFloat(el.dataset.depth) || 1;
      
      // INVERTED direction (opposite to mouse)
      const tx = -mouse.x * depth * 55;
      const ty = -mouse.y * depth * 45;

      // Inertia per element
      positions[i].x += (tx - positions[i].x) * 0.07;
      positions[i].y += (ty - positions[i].y) * 0.07;

      // Apply transform + subtle tilt based on velocity if desired
      el.style.transform = `translate3d(${positions[i].x}px, ${positions[i].y}px, 0)`;
    });

    requestAnimationFrame(tick);
  }
  tick();
})();


/* ---- 2. TEXT ROTATOR ---- */
(function initRotator() {
  const words = [
    "stronger 💪",
    "smarter 🧠",
    "resilient 🛡️",
    "connected 🤝",
    "confident ✨",
    "profitable 💰",
    "informed 📚",
    "unstoppable 🚀",
    "heard 📣",
    "thriving 🌱",
    "funky 🪩",
  ];

  const track = document.getElementById('rotate-track');
  if (!track) return;

  const ROTATION_INTERVAL = 3000; // ms between word changes
  const STAGGER_DELAY     = 0.03; // seconds between chars (exit)
  const STAGGER_ENTER     = 0.02; // seconds between chars (enter)

  let currentIndex = 0;

  // Helper to measure word width accurately
  const measurementSpan = document.createElement('span');
  measurementSpan.style.visibility = 'hidden';
  measurementSpan.style.position = 'absolute';
  measurementSpan.style.whiteSpace = 'nowrap';
  measurementSpan.style.pointerEvents = 'none';
  // Ensure it inherits the exact font styles from the headline
  measurementSpan.style.font = 'inherit';
  measurementSpan.style.letterSpacing = 'inherit';
  measurementSpan.style.textTransform = 'inherit';
  
  measurementSpan.className = 'rotate-word'; 
  track.parentElement.appendChild(measurementSpan);

  function updateWrapperWidth(text) {
    measurementSpan.textContent = text;
    // Use getBoundingClientRect for sub-pixel precision
    const width = measurementSpan.getBoundingClientRect().width;
    const wrapper = track.parentElement;
    wrapper.style.width = `${width}px`;
  }

  // Split word into <span class="rotate-char"> spans
  function buildWord(text) {
    const span = document.createElement('span');
    span.className = 'rotate-word';

    const chars = typeof Intl !== 'undefined' && 'Segmenter' in Intl
      ? Array.from(new Intl.Segmenter('en', { granularity: 'grapheme' }).segment(text), s => s.segment)
      : Array.from(text);

    chars.forEach(ch => {
      const c = document.createElement('span');
      c.className = 'rotate-char';
      c.textContent = ch;
      span.appendChild(c);
    });
    return span;
  }

  function animateIn(wordEl, delay0 = 0) {
    const chars = wordEl.querySelectorAll('.rotate-char');
    chars.forEach((c, i) => {
      c.style.opacity   = '0';
      c.style.transform = 'translateY(100%)';
      c.style.transition = `transform 0.4s cubic-bezier(.22,1,.36,1) ${delay0 + i * STAGGER_ENTER}s,
                             opacity   0.3s ease ${delay0 + i * STAGGER_ENTER}s`;
      requestAnimationFrame(() => requestAnimationFrame(() => {
        c.style.opacity   = '1';
        c.style.transform = 'translateY(0)';
      }));
    });
  }

  function animateOut(wordEl, onDone) {
    const chars = wordEl.querySelectorAll('.rotate-char');
    const lastDelay = (chars.length - 1) * STAGGER_DELAY;

    chars.forEach((c, i) => {
      const d = (chars.length - 1 - i) * STAGGER_DELAY;
      c.style.transition = `transform 0.35s cubic-bezier(.55,0,1,.45) ${d}s,
                             opacity   0.3s ease ${d}s`;
      requestAnimationFrame(() => requestAnimationFrame(() => {
        c.style.opacity   = '0';
        c.style.transform = 'translateY(-120%)';
      }));
    });

    setTimeout(onDone, (lastDelay + 0.4) * 1000);
  }

  // --- Initial render ---
  const firstWordText = words[0];
  const firstWord = buildWord(firstWordText);
  updateWrapperWidth(firstWordText);
  track.appendChild(firstWord);
  animateIn(firstWord, 0.9);

  // --- Rotation loop ---
  setInterval(() => {
    const nextIndex = (currentIndex + 1) % words.length;
    const nextWordText = words[nextIndex];
    const outWord   = track.querySelector('.rotate-word');
    const inWord    = buildWord(nextWordText);

    // Dynamic width update triggers the layout reflow (smooth glide for "become")
    updateWrapperWidth(nextWordText);

    inWord.querySelectorAll('.rotate-char').forEach(c => {
      c.style.opacity   = '0';
      c.style.transform = 'translateY(100%)';
    });
    track.appendChild(inWord);

    animateOut(outWord, () => outWord.remove());
    animateIn(inWord, 0.1);

    currentIndex = nextIndex;
  }, ROTATION_INTERVAL);

})();
</script>
