---
import MailchimpSignupForm from './MailchimpSignupForm.astro';
---

<!-- Newsletter Modal Overlay -->
<div
  id="newsletter-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Subscribe to SBI Newsletter"
  aria-hidden="true"
  style="display:none;"
>
  <div class="modal-backdrop" id="modal-backdrop"></div>
  <div class="modal-box">
    <button class="modal-close" id="modal-close" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2"
          stroke-linecap="round"/>
      </svg>
    </button>
    <MailchimpSignupForm />
  </div>
</div>

<style>
#newsletter-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(4px);
  animation: modal-fade-in .2s ease both;
}

.modal-box {
  position: relative;
  z-index: 1;
  animation: modal-slide-in .25s ease both;
  width: 100%;
  max-width: 500px;
}

.modal-close {
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 2;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: 1px solid #e2ddd5;
  background: #fff;
  color: #625d54;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s, color .15s;
}
.modal-close:hover {
  background: #f0ece6;
  color: #1c1b18;
}

@keyframes modal-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes modal-slide-in {
  from { opacity: 0; transform: translateY(16px) scale(.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
</style>

<script>
  function openModal() {
    const overlay = document.getElementById('newsletter-overlay');
    if (!overlay) return;
    overlay.style.display = 'flex';
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    const emailInput = overlay.querySelector('input[type="email"]');
    if (emailInput) setTimeout(() => (emailInput as HTMLInputElement).focus(), 80);
  }

  function closeModal() {
    const overlay = document.getElementById('newsletter-overlay');
    if (!overlay) return;
    overlay.style.display = 'none';
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Single delegated click listener on document — works regardless of
  // when elements are added to the DOM and survives View Transitions.
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest(
      '#header-join-trigger, #hero-template-trigger, [data-newsletter-trigger]'
    );
    if (trigger) {
      e.preventDefault();
      openModal();
      return;
    }
    if (target.closest('#modal-close') || target.id === 'modal-backdrop') {
      closeModal();
    }
  });

  // Escape key — registered once, never duplicated
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
