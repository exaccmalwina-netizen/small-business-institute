---
import MailchimpSignupForm from './MailchimpSignupForm.jsx';
---

<!-- Newsletter Modal Overlay -->
<div
  id="newsletter-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Subscribe to SBI Newsletter"
  aria-hidden="true"
  style="display:none;"
>
  <div class="modal-backdrop" id="modal-backdrop"></div>
  <div class="modal-box">
    <button class="modal-close" id="modal-close" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2"
          stroke-linecap="round"/>
      </svg>
    </button>
    <MailchimpSignupForm client:load />
  </div>
</div>

<style>
#newsletter-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.55);
  backdrop-filter: blur(4px);
  animation: modal-fade-in .2s ease both;
}

.modal-box {
  position: relative;
  z-index: 1;
  animation: modal-slide-in .25s ease both;
  width: 100%;
  max-width: 500px;
}

.modal-close {
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 2;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: 1px solid #e2ddd5;
  background: #fff;
  color: #625d54;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s, color .15s;
}
.modal-close:hover {
  background: #f0ece6;
  color: #1c1b18;
}

@keyframes modal-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes modal-slide-in {
  from { opacity: 0; transform: translateY(16px) scale(.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
</style>

<script>
  function openModal() {
    const overlay = document.getElementById('newsletter-overlay');
    if (!overlay) return;
    overlay.style.display = 'flex';
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    // focus the email input if available
    const emailInput = overlay.querySelector('input[type="email"]');
    if (emailInput) setTimeout(() => (emailInput as HTMLInputElement).focus(), 50);
  }

  function closeModal() {
    const overlay = document.getElementById('newsletter-overlay');
    if (!overlay) return;
    overlay.style.display = 'none';
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function init() {
    // Close button
    document.getElementById('modal-close')?.addEventListener('click', closeModal);

    // Backdrop click
    document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Header "Join SBI" button
    document.getElementById('header-join-trigger')?.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });

    // Hero "Get Template" button
    document.getElementById('hero-template-trigger')?.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });

    // Any element with data-newsletter-trigger attribute
    document.querySelectorAll('[data-newsletter-trigger]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
    });
  }

  // Works with Astro View Transitions
  document.addEventListener('astro:page-load', init);
  init();
</script>
