---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPosts } from '../../utils/wp.js';
import { getCollection } from 'astro:content';
import { extractKeywords } from '../../utils/tags.js';

// Try WordPress first, fall back to local markdown
const wpRaw = await getPosts(100);

type PostItem = {
    id: string;
    data: {
        title: string;
        category: string;
        categoryName: string;
        date: Date;
        excerpt: string;
        contentHTML?: string;
        tags: string[];
    };
};

let allPosts: PostItem[] = [];

if (wpRaw.length > 0) {
    // WordPress mode
    allPosts = (wpRaw as any[]).map((post) => ({
        id: post.slug,
        data: {
            title: post.title.rendered,
            category: post._embedded?.['wp:term']?.[0]?.[0]?.slug || 'uncategorized',
            categoryName: post._embedded?.['wp:term']?.[0]?.[0]?.name || 'Uncategorized',
            date: new Date(post.date),
            excerpt: post.excerpt.rendered.replace(/(<([^>]+)>)/gi, '').substring(0, 160) + '…',
            contentHTML: post.content.rendered,
            tags: extractKeywords(post.content.rendered, 3)
        },
    }));
} else {
    // Fallback: local markdown (dev mode / WP not yet configured)
    const mdPosts = await getCollection('blog');
    allPosts = mdPosts.map(p => ({
        id: p.id,
        data: {
            title: p.data.title,
            category: p.data.category,
            categoryName: p.data.categoryName,
            date: p.data.date,
            excerpt: p.data.excerpt,
            contentHTML: p.body || '',
            tags: extractKeywords(p.body || '', 3)
        },
    }));
}

allPosts.sort((a: PostItem, b: PostItem) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = [
    'employment',
    'business-management',
    'compliance',
    'insurance',
    'new-technologies',
    'success-stories',
    'failure-stories',
];

const categoryNames: Record<string, string> = {
    'employment':           'Employment',
    'business-management':  'Business Management',
    'compliance':           'Compliance',
    'insurance':            'Insurance',
    'new-technologies':     'New Technologies',
    'success-stories':      'Success Stories',
    'failure-stories':      'Failure Stories',
};

const categoryColors: Record<string, string> = {
    'employment':           '#0284c7',
    'business-management':  '#7c3aed',
    'compliance':           '#059669',
    'insurance':            '#1e293b',
    'new-technologies':     '#7c3aed',
    'success-stories':      '#f59e0b',
    'failure-stories':      '#e11d48',
};
---

<Layout title="Resources & Articles | Small Business Institute">
	<Header />

	<main>
		<div class="blog-header">
			<div class="container text-center">
				<h1 id="page-title">Resources & Articles</h1>
				<p class="hero-subtitle">Plain-English guides for Australian small business owners.</p>
			</div>
		</div>

		<div class="section">
			<div class="container">
                <!-- Search container -->
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        <input type="search" id="article-search" placeholder="Search guides, strategies, words..." aria-label="Search articles" autocomplete="off" />
                    </div>
                </div>

				<!-- Category filter pills -->
				<div class="category-pills" id="category-filters">
					<button class="pill active" data-filter="all">All</button>
                    {categories.map(cat => (
                        <button class="pill" data-filter={cat} style={`--pill-color: ${categoryColors[cat as keyof typeof categoryColors]}`}>
                            {categoryNames[cat as keyof typeof categoryNames]}
                        </button>
                    ))}
				</div>

                {allPosts.length === 0 ? (
                    <div class="empty-state">
                        <p class="empty-title">No articles yet.</p>
                        <p>Check back soon — content is on its way.</p>
                    </div>
                ) : (
                    <div class="posts-grid" id="posts-grid">
                        {allPosts.map((post: PostItem) => {
                            const accentColor = categoryColors[post.data.category as keyof typeof categoryColors] || '#0284c7';
                            return (
                                <article
                                    class="post-card"
                                    data-category={post.data.category}
                                    style={`--card-accent: ${accentColor}`}
                                >
                                    <div class="card-stripe"></div>
                                    <div class="post-card-body">
                                        <div class="post-card-meta">
                                            <span class="post-cat-badge">{post.data.categoryName}</span>
                                            <span class="post-date">
                                                {post.data.date.toLocaleDateString('en-AU', {
                                                    year: 'numeric', month: 'long', day: 'numeric'
                                                })}
                                            </span>
                                        </div>
                                        <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
                                        <p>{post.data.excerpt}</p>
                                        
                                        {post.data.tags.length > 0 && (
                                            <div class="post-tags-meta">
                                                {post.data.tags.map((tag: string) => (
                                                    <button class="post-tag-btn" data-tag={tag}>{tag}</button>
                                                ))}
                                            </div>
                                        )}

                                        <div class="post-card-footer">
                                            <a href={`/blog/${post.id}`} class="read-more">Read article →</a>
                                        </div>
                                    </div>
                                </article>
                            );
                        })}
                    </div>
                )}
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
.blog-header {
	padding: 5rem 0 4rem;
	background: var(--navy);
	color: var(--white);
	border-bottom: 2px solid var(--accent);
}
.blog-header h1 {
	font-size: clamp(2rem, 5vw, 3.5rem);
	font-weight: 800;
	color: var(--white);
	margin-bottom: 1rem;
	letter-spacing: -0.02em;
}
.hero-subtitle {
	font-size: 1.25rem;
	color: rgba(255,255,255,0.8);
	max-width: 700px;
	margin: 0 auto;
	line-height: 1.6;
}
.text-center { text-align: center; }

.section {
	padding: 4rem 0 6rem;
	background: var(--light);
}

/* Filter pills */
.category-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 3rem;
    justify-content: center;
}
.pill {
    background: transparent;
    border: 1.5px solid var(--border);
    color: var(--navy-mid);
    padding: 0.45rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font-body);
}
.pill:hover {
    border-color: var(--pill-color, var(--accent));
    color: var(--pill-color, var(--accent));
}
.pill.active {
    background: var(--pill-color, var(--navy));
    color: #fff;
    border-color: var(--pill-color, var(--navy));
}
.pill[data-filter="all"] { --pill-color: var(--navy); }

/* Grid */
.posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.75rem;
}

/* Search */
.search-container {
    max-width: 600px;
    margin: 0 auto 2.5rem;
}
.search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}
.search-icon {
    position: absolute;
    left: 1.25rem;
    color: var(--muted);
    pointer-events: none;
}
#article-search {
    width: 100%;
    padding: 1.2rem 1.25rem 1.2rem 3.5rem;
    font-size: 1.05rem;
    font-family: var(--font-body);
    border: 2px solid var(--border);
    border-radius: 50px;
    background: var(--white);
    color: var(--navy);
    transition: all 0.2s ease;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
}
#article-search:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(2, 132, 199, 0.15);
}
#article-search::placeholder {
    color: var(--muted);
}

/* Card */
.post-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.25s ease;
}
.card-stripe {
    height: 4px;
    background: var(--card-accent);
}
.post-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
    border-color: transparent;
}
.post-card:hover .card-stripe {
    height: 6px;
}
.post-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
}
.post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.82rem;
    margin-bottom: 1rem;
}
.post-cat-badge {
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    color: var(--card-accent);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.post-date { color: var(--muted); }
.post-card h3 {
    font-size: 1.2rem;
    margin: 0 0 0.75rem;
    line-height: 1.35;
    font-family: var(--font-heading);
}
.post-card h3 a {
    color: var(--navy);
    transition: color 0.2s;
}
.post-card:hover h3 a { color: var(--card-accent); }
.post-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex-grow: 1;
}
.post-tags-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
}
.post-tag-btn {
    background: var(--light);
    color: var(--navy-mid);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}
.post-tag-btn:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
}
.post-card-footer {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    margin-top: auto;
}
.read-more {
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--card-accent);
}

/* Empty state */
.empty-state {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--white);
    border-radius: var(--radius-xl);
    border: 2px dashed var(--border);
    color: var(--muted);
}
.empty-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.5rem;
}
</style>

<script>
    const pageTitles: Record<string, string> = {
        'all':                  'Resources & Articles',
        'employment':           'Employment Articles',
        'business-management':  'Business Management Articles',
        'compliance':           'Compliance Articles',
        'insurance':            'Insurance Articles',
        'new-technologies':     'New Technologies Articles',
        'success-stories':      'Success Stories',
        'failure-stories':      'Failure Stories',
    };

    function init() {
        const filters    = document.querySelectorAll('.pill') as NodeListOf<HTMLButtonElement>;
        const posts      = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;
        const title      = document.getElementById('page-title');
        const searchInput = document.getElementById('article-search') as HTMLInputElement | null;
        const tagBtns    = document.querySelectorAll('.post-tag-btn') as NodeListOf<HTMLButtonElement>;

        // Bail out if not on the blog index page
        if (!filters.length && !posts.length) return;

        let currentCategory = 'all';
        let searchQuery = '';

        const executeFilters = () => {
            const query = searchQuery.toLowerCase().trim();

            posts.forEach(post => {
                const matchCategory = currentCategory === 'all' || post.dataset.category === currentCategory;
                const textContent = post.textContent?.toLowerCase() || '';
                const matchSearch = query === '' || textContent.includes(query);
                post.style.display = (matchCategory && matchSearch) ? 'flex' : 'none';
            });

            if (title) {
                title.textContent = query
                    ? `Search results for "${searchQuery}"`
                    : (pageTitles[currentCategory] ?? 'Resources & Articles');
            }
        };

        const updateCategoryFilter = (filterVal: string) => {
            currentCategory = filterVal;
            filters.forEach(f => f.classList.toggle('active', f.dataset.filter === filterVal));
            executeFilters();
        };

        // Category pills
        filters.forEach(btn => {
            btn.addEventListener('click', () => {
                const val = btn.dataset.filter ?? 'all';
                const newUrl = val === 'all' ? '/blog' : `/blog?cat=${val}`;
                window.history.pushState({}, '', newUrl);
                updateCategoryFilter(val);
            });
        });

        // Search input
        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                searchQuery = (e.target as HTMLInputElement).value;
                executeFilters();
                const currentUrl = new URL(window.location.href);
                if (searchQuery) currentUrl.searchParams.set('search', searchQuery);
                else currentUrl.searchParams.delete('search');
                window.history.replaceState({}, '', currentUrl.toString());
            });
        }

        // Tag buttons on cards
        tagBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                const val = btn.dataset.tag || '';
                if (searchInput) {
                    searchInput.value = val;
                    searchInput.dispatchEvent(new Event('input'));
                }
            });
        });

        // Browser back/forward restores URL state
        window.addEventListener('popstate', () => {
            const params = new URLSearchParams(window.location.search);
            const cat = params.get('cat') ?? 'all';
            const search = params.get('search') ?? '';
            if (searchInput) searchInput.value = search;
            searchQuery = search;
            updateCategoryFilter(cat);
        });

        // Read initial state from URL
        const urlParams = new URLSearchParams(window.location.search);
        const initialSearch = urlParams.get('search') ?? '';
        const initialCat    = urlParams.get('cat')    ?? 'all';
        if (searchInput) searchInput.value = initialSearch;
        searchQuery = initialSearch;
        updateCategoryFilter(initialCat);
    }

    // Re-run on every Astro View Transition navigation
    document.addEventListener('astro:page-load', init);
    init();
</script>
