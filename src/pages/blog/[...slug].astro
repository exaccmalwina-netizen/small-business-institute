---
import { getPosts } from '../../utils/wp.js';
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
    const wpPosts = await getPosts(100);

    if ((wpPosts as any[]).length > 0) {
        // WordPress mode: generate a page per WP post
        return (wpPosts as any[]).map(post => ({
            params: { slug: post.slug },
            props: { source: 'wp' as const, post, entry: undefined },
        }));
    }

    // Fallback: local markdown (dev / WP not yet configured)
    const mdPosts = await getCollection('blog');
    return mdPosts.map(entry => ({
        params: { slug: entry.id },
        props: { source: 'md' as const, post: undefined, entry },
    }));
}

const { source, post, entry } = Astro.props;

let articleTitle = '';
let category = '';
let categoryName = '';
let articleDate = new Date();
let author = 'SBI Editorial Team';
let contentHTML = '';
let MdContent: any = null;

if (source === 'wp') {
    articleTitle  = post.title.rendered;
    category      = post._embedded?.['wp:term']?.[0]?.[0]?.slug ?? 'uncategorized';
    categoryName  = post._embedded?.['wp:term']?.[0]?.[0]?.name ?? 'Uncategorized';
    articleDate   = new Date(post.date);
    author        = post._embedded?.author?.[0]?.name ?? 'SBI Editorial Team';
    contentHTML   = post.content.rendered;
} else if (entry) {
    articleTitle  = entry.data.title;
    category      = entry.data.category;
    categoryName  = entry.data.categoryName;
    articleDate   = entry.data.date;
    author        = entry.data.author ?? 'SBI Editorial Team';
    const rendered = await render(entry);
    MdContent = rendered.Content;
}
---

<Layout title={`${articleTitle} | Small Business Institute`}>
    <Header />

    <main class="article-wrapper">
        <article class="prose-container">
            <header class="article-header">
                <div class="article-meta">
                    <a href={`/blog?cat=${category}`} class="post-cat-badge">{categoryName}</a>
                    <span class="post-date">
                        {articleDate.toLocaleDateString('en-AU', {
                            year: 'numeric', month: 'long', day: 'numeric'
                        })}
                    </span>
                </div>
                <h1>{articleTitle}</h1>
                <p class="article-author">By {author}</p>
            </header>

            <div class="prose">
                {source === 'wp'
                    ? <div set:html={contentHTML} />
                    : MdContent && <MdContent />
                }
            </div>

            <div class="article-footer">
                <div class="newsletter-inline">
                    <h3>Was this helpful?</h3>
                    <p>Subscribe to our newsletter for more no-fluff guides.</p>
                    <button class="btn-primary" id="article-newsletter-trigger">Subscribe now</button>
                </div>
            </div>
        </article>
    </main>

    <Footer />
</Layout>

<style>
.article-wrapper {
    background: var(--card-bg);
    padding: 4rem 0 6rem;
}
.prose-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.25rem;
}

.article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
}

.article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.post-cat-badge {
    background: var(--accent-lt);
    color: var(--accent);
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
}
.post-cat-badge:hover {
    background: #bae6fd;
    text-decoration: none;
}
.post-date {
    color: var(--muted);
    font-size: 0.95rem;
}

.article-header h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--navy);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
}
.article-author {
    color: var(--navy-mid);
    font-weight: 600;
    font-size: 1.05rem;
}

/* Prose styles */
.prose {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text);
}
.prose :global(h2) {
    font-size: 2rem;
    color: var(--navy);
    margin: 3rem 0 1.25rem;
    font-weight: 700;
    line-height: 1.3;
}
.prose :global(h3) {
    font-size: 1.5rem;
    color: var(--navy);
    margin: 2rem 0 1rem;
    font-weight: 600;
}
.prose :global(p) { margin-bottom: 1.5rem; }
.prose :global(ul), .prose :global(ol) { margin-bottom: 1.5rem; padding-left: 1.5rem; }
.prose :global(li) { margin-bottom: 0.5rem; }
.prose :global(strong) { color: var(--navy); }
.prose :global(a) { color: var(--accent); text-decoration: underline; }
.prose :global(blockquote) {
    border-left: 4px solid var(--accent);
    padding-left: 1.25rem;
    color: var(--navy-mid);
    font-style: italic;
    margin: 2rem 0;
}

.article-footer {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px dashed var(--border);
}

.newsletter-inline {
    padding: 2.5rem;
    background: var(--off-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    text-align: center;
}
.newsletter-inline h3 {
    color: var(--navy);
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    font-weight: 800;
}
.newsletter-inline p {
    color: var(--navy-mid);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
}
</style>

<script>
    const trigger = document.getElementById('article-newsletter-trigger');
    const modal = document.getElementById('newsletter-overlay');
    if (trigger && modal) {
        trigger.addEventListener('click', () => {
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
        });
    }
</script>
